datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String     @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  firstName      Json?      // { az?: string, en?: string } — müəllif üçün dillər üzrə ad
  lastName       Json?      // { az?: string, en?: string } — müəllif üçün dillər üzrə soyad
  email          String     @unique
  password       String
  role           Role       @default(USER)
  profile        Profile?
  sessions       Session[]
  posts          Post[]
  glossaryTerms  Glossary[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Profile {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @unique @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio         String?
  avatarUrl   String?
  location    String?
  profession  Json?    // { az?: string, en?: string } — müəllif üçün dillər üzrə ixtisas
  socialLinks Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Request {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  surname        String
  number         String
  childAge       Int
  childLanguage  Language      @default(AZ)
  message        String?
  additionalInfo Json?
  createdAt      DateTime      @default(now())
  status         RequestStatus @default(PENDING)
  viewedBy       String?
  viewedAt       DateTime?
}

model Post {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  title         Json
  content       Json
  slug          SlugI18n
  published     Boolean  @default(false)
  imageUrl      Json?    // { az?: string, en?: string } - şəkil hər dil üçün ayrı
  imageAlt      Json?    // SEO alt text: { az?, en? }
  tags      Json[]
  authorId  String   @db.ObjectId
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  postType  PostType @default(BLOG)

  eventDate   DateTime?
  eventStatus EventStatus?

  offerStartDate DateTime?
  offerEndDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([slug], name: "uniqueMultilingualSlug")
  @@index([authorId])
  @@index([postType])
  @@index([eventStatus])
}

model PageMeta {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  pageKey     String   // e.g. "courses", "about-us", "contact-us", "course:slug"
  locale      String   // "az" | "en"
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([pageKey, locale], name: "uniquePageMetaKeyLocale")
  @@index([pageKey])
  @@index([locale])
}

model PageSchema {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  pageKey    String   // e.g. "home", "courses", "about-us", "course:slug"
  locale     String   // "az" | "en"
  schemaJson Json     // JSON-LD object or array of objects
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([pageKey, locale], name: "uniquePageSchemaKeyLocale")
  @@index([pageKey])
  @@index([locale])
}

model FaqItem {
  id        String           @id @default(auto()) @map("_id") @db.ObjectId
  question  MultilingualText
  answer    MultilingualText
  order     Int              @default(0)
  pages     String[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([order])
}

model StudentProjectsCategory {
  id        String            @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  projects  StudentProjects[]
}

model StudentProjects {
  id          String                  @id @default(auto()) @map("_id") @db.ObjectId
  title       Json?
  description Json?
  imageUrl    String
  link        String
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  categoryId  String                  @db.ObjectId
  category    StudentProjectsCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  order       Int

  @@index([categoryId])
}

model Team {
  id              String            @id @default(auto()) @map("_id") @db.ObjectId
  name            MultilingualText
  surname         MultilingualText
  fullName        MultilingualText
  imageUrl        String
  imageAlt        MultilingualText?
  createdAt       DateTime          @default(now())
  bio             Json?
  order           Int
  isActive        Boolean           @default(true)
  coursesTeaching CourseToTeacher[]
}

model Gallery {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  imageUrl  String
  imageAlt  MultilingualText?
  title     Json?
  createdAt DateTime @default(now())
  order     Int      @default(0)
}

model ContactInfo {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  email        String
  address      Json?
  address2     Json?
  whatsapp     Json?
  phone        Json?
  workingHours Json?
  socialLinks  Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Course {
  id               String                @id @default(auto()) @map("_id") @db.ObjectId
  title            Json
  description      Json
  shortDescription Json?
  slug             SlugI18n
  icon             String                @default("FaStar")
  duration         Float
  level            Json
  published        Boolean               @default(false)
  modules          CourseToModule[]
  teachers         CourseToTeacher[]
  eligibility      CourseToEligibility[]
  lessonPerWeek    Int?                  @default(3)
  tag              String[]
  newTags          Json?
  imageUrl         String?
  imageAlt         MultilingualText?
  ageRange         String?
  backgroundColor  String?               @default("#FEF3C7")
  borderColor      String?               @default("#F59E0B")
  textColor        String?               @default("#1F2937")
  /// Sıralama: böyük dəyər əvvəl (prioritet). 0 = default.
  order            Int                   @default(0)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@unique([slug], name: "uniqueMultilingualCourseSlug")
  @@index([order])
  @@index([published])
}

model CourseModule {
  id          String           @id @default(auto()) @map("_id") @db.ObjectId
  title       Json
  description Json?
  content     Json
  courses     CourseToModule[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model CourseToModule {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  courseId  String       @db.ObjectId
  course    Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  moduleId  String       @db.ObjectId
  module    CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  order     Int
  createdAt DateTime     @default(now())

  @@unique([courseId, moduleId])
  @@index([courseId])
  @@index([moduleId])
}

model CourseTeacher {
  id          String            @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description Json?
  courses     CourseToTeacher[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model CourseToTeacher {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  position        String?
  courseId        String        @db.ObjectId
  course          Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacherId       String        @db.ObjectId
  teacher         Team          @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  courseTeacherId String        @db.ObjectId
  courseTeacher   CourseTeacher @relation(fields: [courseTeacherId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  @@unique([courseId, teacherId, courseTeacherId])
  @@index([courseId])
  @@index([teacherId])
  @@index([courseTeacherId])
}

model CourseEligibility {
  id          String                @id @default(auto()) @map("_id") @db.ObjectId
  title       Json
  description Json
  icon        String
  /// Admin siyahısı: böyük dəyər yuxarıda (vacancy/course ilə eyni məntiq).
  order       Int                   @default(0)
  courses     CourseToEligibility[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([order])
}

model CourseToEligibility {
  id            String            @id @default(auto()) @map("_id") @db.ObjectId
  courseId      String            @db.ObjectId
  course        Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  eligibilityId String            @db.ObjectId
  eligibility   CourseEligibility @relation(fields: [eligibilityId], references: [id], onDelete: Cascade)
  order         Int               @default(0)
  createdAt     DateTime          @default(now())

  @@unique([courseId, eligibilityId])
  @@index([courseId])
  @@index([eligibilityId])
  @@index([order])
}

enum Language {
  AZ
  EN
}

enum Role {
  USER
  AUTHOR
  CRMOPERATOR
  CONTENTMANAGER
  COORDINATOR
  STAFF
  HRMANAGER
  ADMIN
}

enum RequestStatus {
  VIEWED
  PENDING
}

enum PostType {
  BLOG
  NEWS
  EVENT
  OFFERS
}

enum EventStatus {
  ONGOING
  UPCOMING
  PAST
}

model Vacancy {
  id            String           @id @default(auto()) @map("_id") @db.ObjectId
  title         MultilingualText
  description   MultilingualText
  requirements  MultilingualText?
  /// İş şəraiti (HTML, editor) — MultilingualText { az, en }
  workConditions MultilingualText?
  /// Alt başlıq (məs: Mid-senior) — JSON { az, en }
  jobLevel      Json?
  slug          SlugI18n
  /// Məs: Full-Time, Part-Time
  employmentType String?
  /// Son müraciət tarixi
  deadline      DateTime?
  /// Teqlər (admin üçün)
  tags          Json?
  isActive      Boolean          @default(true)
  order         Int              @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@unique([slug], name: "uniqueMultilingualVacancySlug")
  @@index([isActive])
  @@index([order])
}

type SlugI18n {
  az String
  en String
}

model Glossary {
  id           String            @id @default(auto()) @map("_id") @db.ObjectId
  term         MultilingualText
  definition   MultilingualText
  slug         SlugI18n
  category     GlossaryCategory? @relation(fields: [categoryId], references: [id])
  categoryId   String?           @db.ObjectId
  authorId     String?           @db.ObjectId
  author       User?             @relation(fields: [authorId], references: [id], onDelete: SetNull)
  published    Boolean           @default(false)
  relatedTerms String[]          @db.ObjectId
  tags         Json?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@unique([slug], name: "uniqueMultilingualGlossarySlug")
  @@index([categoryId])
  @@index([authorId])
}

model GlossaryCategory {
  id            String            @id @default(auto()) @map("_id") @db.ObjectId
  name          MultilingualText
  description   MultilingualText?
  slug          SlugI18n
  glossaryTerms Glossary[]
  order         Int               @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([slug], name: "uniqueMultilingualGlossaryCategorySlug")
}

model Graduate {
  id          String            @id @default(auto()) @map("_id") @db.ObjectId
  name        MultilingualText
  story       MultilingualText
  /// "image" | "youtube"
  mediaType   String            @default("image")
  /// YouTube URL or uploaded image path
  mediaUrl    String
  courseId     String?           @db.ObjectId
  courseName  MultilingualText?
  isActive    Boolean           @default(true)
  order       Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([isActive])
  @@index([order])
}

type MultilingualText {
  az String
  en String
}

/// Ana səhifə hero: tək sənəd. `contentHtml` / `imageAlt` — { az, en } JSON.
model HomeHero {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  contentHtml Json?
  imageAlt    Json?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// Haqqımızda: intro + missiya/vizyon (mətn və şəkil — tək sənəd).
model AboutPageContent {
  id    String @id @default(auto()) @map("_id") @db.ObjectId

  introTitle        Json?
  introDescription1 Json?
  introDescription2 Json?
  introDescription3 Json?
  introImageUrl     String?
  introImageAlt     Json?

  missionSectionTitle   Json?
  missionTitle          Json?
  missionDescription    Json?
  visionTitle           Json?
  visionDescription     Json?
  missionVisionImageUrl String?
  missionVisionImageAlt Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
